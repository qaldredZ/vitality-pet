import 'package:flutter/material.dart';

void main() {
  runApp(const PetStepTrackerApp());
}

class PetStepTrackerApp extends StatelessWidget {
  const PetStepTrackerApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Pet Step Tracker',
      debugShowCheckedModeBanner: false,
      theme: ThemeData(
        fontFamily: 'Nunito',
        scaffoldBackgroundColor: const Color(0xFFF0F4E8),
      ),
      home: const PetTrackerScreen(),
    );
  }
}

class PetTrackerScreen extends StatelessWidget {
  const PetTrackerScreen({super.key});

  static const String petName = 'Browny';
  static const int currentSteps = 2000;
  static const int dailyGoal = 5000;
  static const List<int> milestones = [0, 2000, 20000, 35000, 50000];

  static const String dogImagePath = 'assets/images/dog.png';

  @override
  Widget build(BuildContext context) {
    final double progressFraction =
    (currentSteps / milestones.last).clamp(0.0, 1.0);

    return Scaffold(
      backgroundColor: const Color(0xFFF0F4E8),
      body: SafeArea(
        child: SingleChildScrollView(
          padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 16),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              _ProgressBarSection(
                milestones: milestones,
                progressFraction: progressFraction,
              ),
              const SizedBox(height: 20),
              _PetCard(
                petName: petName,
                dogImagePath: dogImagePath,
              ),
              const SizedBox(height: 20),
              _StepsTodayCard(steps: currentSteps),
              const SizedBox(height: 14),
              _InfoCard(
                title: '$petName is feeling Vibrant!',
                subtitle: 'Do your daily goals to maintain your pet\'s energy.',
                dogImagePath: dogImagePath,
                backgroundColor: const Color(0xFFFFFDE7),
                borderColor: const Color(0xFFFFD54F),
              ),
              const SizedBox(height: 12),
              _InfoCard(
                title: 'Daily Goal: $currentSteps/$dailyGoal Steps.',
                subtitle: 'Please complete your daily goals to earn rewards.',
                dogImagePath: dogImagePath,
                backgroundColor: const Color(0xFFE8F5E9),
                borderColor: const Color(0xFF81C784),
              ),
              const SizedBox(height: 20),
              const _RewardCard(),
              const SizedBox(height: 24),
            ],
          ),
        ),
      ),
    );
  }
}

class _ProgressBarSection extends StatelessWidget {
  const _ProgressBarSection({
    required this.milestones,
    required this.progressFraction,
  });

  final List<int> milestones;
  final double progressFraction;

  @override
  Widget build(BuildContext context) {
    return Row(
      crossAxisAlignment: CrossAxisAlignment.center,
      children: [
        Expanded(
          child: Column(
            children: [
              Row(
                mainAxisAlignment: MainAxisAlignment.spaceBetween,
                children: milestones.map((m) {
                  final bool reached =
                      m <= (progressFraction * milestones.last);
                  return _MilestoneDot(reached: reached);
                }).toList(),
              ),
              const SizedBox(height: 6),
              ClipRRect(
                borderRadius: BorderRadius.circular(8),
                child: LinearProgressIndicator(
                  value: progressFraction,
                  minHeight: 14,
                  backgroundColor: const Color(0xFFDDE8C8),
                  valueColor: const AlwaysStoppedAnimation<Color>(
                    Color(0xFF8BC34A),
                  ),
                ),
              ),
              const SizedBox(height: 6),
              Row(
                mainAxisAlignment: MainAxisAlignment.spaceBetween,
                children: milestones.map((m) {
                  return Text(
                    m == 0 ? '0' : _formatNumber(m),
                    style: const TextStyle(
                      fontSize: 10,
                      color: Color(0xFF7A8B6F),
                      fontWeight: FontWeight.w500,
                    ),
                  );
                }).toList(),
              ),
            ],
          ),
        ),
        const SizedBox(width: 12),
        GestureDetector(
          onTap: () {
            Navigator.push(
              context,
              MaterialPageRoute(builder: (context) => const SettingsScreen()),
            );
          },
          child: Container(
            decoration: BoxDecoration(
              color: const Color(0xFFDDE8C8),
              borderRadius: BorderRadius.circular(8),
            ),
            padding: const EdgeInsets.all(6),
            child: const Icon(Icons.settings, size: 20, color: Color(0xFF5D7A4A)),
          ),
        ),
      ],
    );
  }

  String _formatNumber(int n) {
    if (n >= 1000) return '${(n / 1000).toStringAsFixed(0)}k';
    return n.toString();
  }
}

class _MilestoneDot extends StatelessWidget {
  const _MilestoneDot({required this.reached});
  final bool reached;

  @override
  Widget build(BuildContext context) {
    return Container(
      width: 10,
      height: 10,
      decoration: BoxDecoration(
        shape: BoxShape.circle,
        color: reached ? const Color(0xFF8BC34A) : const Color(0xFFBBCCA0),
        border: Border.all(color: Colors.white, width: 1.5),
      ),
    );
  }
}

